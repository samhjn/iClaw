<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.iclaw.cronjob.refresh</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.iclaw.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>iclaw</string>
				<string>agentfile</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>iClaw needs access to your calendars so the AI agent can create, read, and manage calendar events on your behalf.</string>
	<key>NSCameraUsageDescription</key>
	<string>iClaw needs camera access to capture photos for use in conversations with the AI agent.</string>
	<key>NSContactsUsageDescription</key>
	<string>iClaw needs access to your contacts so the AI agent can look up contact information when you ask.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>iClaw needs read access to your Health data so the AI agent can analyze trends such as steps, sleep, heart rate, and body metrics.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>iClaw needs write access to your Health data so the AI agent can log entries such as calorie intake and body metrics.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>iClaw needs your location to provide location-aware responses, nearby place searches, and directions.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>iClaw needs photo library access to attach images to conversations with the AI agent.</string>
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>iClaw needs access to your reminders so the AI agent can create, complete, and manage reminders on your behalf.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
	</array>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
